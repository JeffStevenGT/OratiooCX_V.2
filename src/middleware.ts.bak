/**
 * middleware.ts — Protección de Rutas (sin DB, Edge-safe)
 * =========================================================
 * No importa ningún módulo Node.js.
 * Solo verifica el token JWT de NextAuth desde la cookie.
 */

import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';

// Mapa de rutas protegidas por rol
const ROLE_ROUTES: Record<string, string[]> = {
  '/asesor': ['asesor'],
  '/supervisor': ['supervisor'],
  '/jefe': ['jefe_area'],
  '/backoffice': ['back_office'],
  '/admin': ['it', 'desarrollador'],
  '/clientes': ['supervisor', 'jefe_area', 'it', 'desarrollador'],
  '/proyectos': ['jefe_area', 'desarrollador'],
  '/tramitacion': ['back_office'],
  '/usuarios': ['jefe_area', 'desarrollador'],
  '/infraestructura': ['it', 'desarrollador'],
  '/bots': ['it', 'desarrollador'],
  '/documentos': ['supervisor', 'jefe_area', 'it', 'desarrollador'],
  '/power-dialer': ['asesor', 'supervisor'],
};

function parseJwt(token: string): any {
  try {
    const base64 = token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/');
    return JSON.parse(Buffer.from(base64, 'base64').toString());
  } catch {
    return null;
  }
}

export default function middleware(req: NextRequest) {
  const path = req.nextUrl.pathname;

  // Rutas públicas
  if (path === '/login' || path.startsWith('/api/auth') || path.startsWith('/_next')) {
    return NextResponse.next();
  }

  // Verificar sesión por cookie de NextAuth
  const sessionToken =
    req.cookies.get('__Secure-authjs.session-token')?.value ||
    req.cookies.get('authjs.session-token')?.value;

  if (!sessionToken) {
    return NextResponse.redirect(new URL('/login', req.url));
  }

  const payload = parseJwt(sessionToken);
  if (!payload) {
    return NextResponse.redirect(new URL('/login', req.url));
  }

  // Verificar expiración
  if (payload.exp && Date.now() > payload.exp * 1000) {
    return NextResponse.redirect(new URL('/login', req.url));
  }

  const userRole = payload.role || 'asesor';

  // Verificar permisos de rol
  const allowedRoles = ROLE_ROUTES[path];
  if (allowedRoles && !allowedRoles.includes(userRole)) {
    const redirectMap: Record<string, string> = {
      asesor: '/asesor',
      supervisor: '/supervisor',
      jefe_area: '/jefe',
      back_office: '/backoffice',
      it: '/admin',
      desarrollador: '/admin',
    };
    return NextResponse.redirect(new URL(redirectMap[userRole] || '/login', req.url));
  }

  return NextResponse.next();
}

export const config = {
  matcher: ['/((?!_next/static|_next/image|favicon.ico).*)'],
};
