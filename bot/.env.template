# Oratioo Bot — Variables de Entorno (PC Local)
# ==============================================
# Copiar a .env y reemplazar los valores.

# ── Conexión al VPS ──
BOT_API_URL=https://www.app.oratioo.com
BOT_API_KEY=GENERAR_VALOR_ALEATORIO_64_CHARS

# ── Credenciales Pangea ──
ORANGE_USER=usuario_pangea
ORANGE_PASS=contraseña_pangea

# ── Headless ──
# En producción dejar comentado (headless=True por defecto)
# Descomentar solo para debug visual del navegador:
# BOT_HEADLESS=0
