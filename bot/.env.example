# ═══════════════════════════════════════════════════
# ORATIOO CX - Variables de Entorno (ejemplo)
# ═══════════════════════════════════════════════════
# Copia este archivo como .env y completa los valores
# ═══════════════════════════════════════════════════

# Supabase (URL del proyecto + Service Role Key)
# Obtener de: Supabase Dashboard > Settings > API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key-aqui

# Nombre de esta máquina (debe coincidir con el configurado en la web)
MAQUINA_NOMBRE=PC-Nombre

# Credenciales de Orange Pangea
ORANGE_USER=tu-usuario-orange
ORANGE_PASS=tu-contraseña-orange
