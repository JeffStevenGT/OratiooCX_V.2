# Oratioo CX — Variables de Entorno (Producción)
# ==============================================
# Copiar este archivo a .env.production y reemplazar los valores.
# NUNCA subir .env.production al repositorio.

# ── Base de Datos ──
# Docker: postgresql://postgres:CONTRASEÑA@db:5432/oratioo_cx
# VPS directo: postgresql://postgres:CONTRASEÑA@localhost:5432/oratioo_cx
DATABASE_URL=postgresql://postgres:CONTRASEÑA_SEGURA@db:5432/oratioo_cx

# ── NextAuth ──
# Generar: openssl rand -hex 32
NEXTAUTH_SECRET=GENERAR_VALOR_ALEATORIO_64_CHARS
NEXTAUTH_URL=https://oratioo.tudominio.com

# ── VPBX ──
VPBX_API_KEY=sk_live_...
VPBX_API_URL=https://vpbx.me/api

# ── Bot Pangea ──
# Generar: openssl rand -hex 32
BOT_API_KEY=GENERAR_VALOR_ALEATORIO_64_CHARS

# ── Orange Pangea (solo lo necesita el bot en PC local) ──
ORANGE_USER=usuario_pangea
ORANGE_PASS=contraseña_pangea

# ── Redis (opcional, quitar si no se usa) ──
# REDIS_URL=redis://default:CONTRASEÑA@redis:6379
# REDIS_TOKEN=

# ── WhatsApp Meta (opcional) ──
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# WHATSAPP_VERIFY_TOKEN=
