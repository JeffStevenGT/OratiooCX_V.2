# ============================================================
# Oratioo CX — Variables de Entorno (Producción — VPS)
# ============================================================
# Copiar a .env.production y reemplazar TODOS los valores.
# NUNCA subir .env.production al repo (está en .gitignore).
# ============================================================

# ── Base de Datos ──
# Docker: el servicio se llama "db"
DATABASE_URL=postgresql://oratioo:CONTRASEÑA_DB@db:5432/oratioo_cx

# ── NextAuth ──
# Generar: openssl rand -hex 32
NEXTAUTH_SECRET=GENERAR_64_CHARS_ALEATORIOS
NEXTAUTH_URL=https://www.app.oratioo.com

# ── Bot (OBLIGATORIO) ──
# Generar: openssl rand -hex 32
# Esta misma clave debe estar en el .env de la PC del bot
BOT_API_KEY=GENERAR_64_CHARS_ALEATORIOS

# ── PostgreSQL Docker ──
# Contraseña del usuario "oratioo" en el contenedor db
DB_PASSWORD=CONTRASEÑA_SEGURA_PARA_POSTGRES

# ── VPBX ──
VPBX_API_KEY=59JYklPn67GsjKKpyPFqr2n9jvQc7p3N
VPBX_API_URL=https://vpbx.me/api

